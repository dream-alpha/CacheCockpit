<?xml version="1.0" ?>
<skin>
	<layouts>
		<layout name="CACColor_Buttons_Labels">
			<widget backgroundColor="#9f1313" font="Regular;30" foregroundColor="white" halign="center" name="key_red" position="10,0" shadowColor="black" shadowOffset="-2,-2" size="300,70" transparent="1" valign="center" zPosition="1"/>
			<widget backgroundColor="#1f771f" font="Regular;30" foregroundColor="white" halign="center" name="key_green" position="310,0" shadowColor="black" shadowOffset="-2,-2" size="300,70" transparent="1" valign="center" zPosition="1"/>
			<widget backgroundColor="#a08500" font="Regular;30" foregroundColor="white" halign="center" name="key_yellow" position="610,0" shadowColor="black" shadowOffset="-2,-2" size="300,70" transparent="1" valign="center" zPosition="1"/>
			<widget backgroundColor="#18188b" font="Regular;30" foregroundColor="white" halign="center" name="key_blue" position="910,0" shadowColor="black" shadowOffset="-2,-2" size="300,70" transparent="1" valign="center" zPosition="1"/>
		</layout>
		<layout name="CACDate">
			<widget font="Regular;34" halign="right" position="1240,0" render="Label" size="400,70" source="global.CurrentTime" valign="center">
				<convert type="ClockToText">Date</convert>
			</widget>
		</layout>
		<layout name="CACTime">
			<widget font="Regular;34" halign="right" position="1650,0" render="Label" size="120,70" source="global.CurrentTime" valign="center">
				<convert type="ClockToText">Default</convert>
			</widget>
		</layout>
		<layout name="CACColor_Buttons">
			<ePixmap pixmap="Default-FHD/skin_default/buttons/red.svg" position="10,0" size="300,70"/>
			<ePixmap pixmap="Default-FHD/skin_default/buttons/green.svg" position="310,0" size="300,70"/>
			<ePixmap pixmap="Default-FHD/skin_default/buttons/yellow.svg" position="610,0" size="300,70"/>
			<ePixmap pixmap="Default-FHD/skin_default/buttons/blue.svg" position="910,0" size="300,70"/>
		</layout>
	</layouts>
	<screen name="CACConfigScreen" position="center,110" size="1800,930" title="">
		<layout name="CACColor_Buttons"/>
		<layout name="CACColor_Buttons_Labels"/>
		<layout name="CACDate"/>
		<layout name="CACTime"/>
		<eLabel backgroundColor="grey" position="10,80" size="1780,1"/>
		<widget enableWrapAround="1" itemHeight="45" name="config" position="10,90" scrollbarMode="showOnDemand" size="1780,630"/>
		<eLabel backgroundColor="grey" position="10,730" size="1780,1"/>
		<widget font="Regular;32" halign="center" position="10,740" render="Label" size="1780,180" source="help" valign="center"/>
	</screen>
</skin>
